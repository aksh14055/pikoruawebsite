# ─── Sanity CMS ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=your_read_token          # server-side only — for draft mode
SANITY_WEBHOOK_SECRET=your_webhook_secret      # for ISR revalidation on publish

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key    # safe to expose — RLS denies lead reads
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # server-side ONLY, never expose

# ─── CRM ─────────────────────────────────────────────────────────────────────
# Zoho CRM
ZOHO_CRM_CLIENT_ID=
ZOHO_CRM_CLIENT_SECRET=
ZOHO_CRM_REFRESH_TOKEN=
# OR HubSpot
HUBSPOT_API_KEY=

# ─── Email (Resend & Brevo) ───────────────────────────────────────────────────
RESEND_API_KEY=your_resend_key
TEAM_NOTIFICATION_EMAIL=connect@pikorua.in

# Brevo (formerly Sendinblue) / Brave API configuration
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_verified_sender_email@domain.com
BREVO_SENDER_NAME=PIKORUA Realty

# ─── Analytics (injected via GTM — IDs also stored in Sanity siteSettings) ───
# These are referenced server-side for JSON-LD / SSR only.
# GTM loads GA4 + Pixel on the client via the container.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_FROM_EMAIL=PIKORUA Website <noreply@pikorua.in>   # must be verified in Resend

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=916354359222                 # country code + number, no spaces
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Hi, I'd like to know more about luxury residences in Ahmedabad.

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://pikorua.in
# Set to "true" ONLY when the full Phase 4 site is built and ready to go live.
# Until then this stays "false" — the holding page is shown instead.
NEXT_PUBLIC_SITE_LIVE=false

# ─── Admin Console ────────────────────────────────────────────────────────────
ADMIN_EMAIL=your_admin_email@domain.com
ADMIN_PASSWORD=your_admin_password
